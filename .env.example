# Environment variables declared in this file are available at build time.
# Make sure to copy this file to .env.local and .env for local development.

# Database (configured for Docker setup)
DATABASE_URL="postgresql://postgres:password@localhost:5432/recipe_organizer"

# Next.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="development-secret-change-in-production"

# Development
NODE_ENV="development"